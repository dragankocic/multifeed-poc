        </main>
    </div>

    <script src="sidebar.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const hermesMarketsBody = document.getElementById('hermesMarketsBody');
            const sportSelect = document.getElementById('sportSelect');
            const typeSelect = document.getElementById('typeSelect');
            const searchInput = document.getElementById('searchInput');

            // IZMENJENO: Total Goals je sada tipa Statistics
            const hermesMarkets = [
                { id: "HRM-001", name: "1X2", desc: "Home, Draw, Away match winner", type: "Regular", sport: "Soccer" },
                { id: "HRM-002", name: "Asian Handicap", desc: "Handicap betting for the match", type: "Regular", sport: "Soccer" },
                { id: "HRM-003", name: "Total Goals", desc: "Over/Under total goals", type: "Statistics", sport: "Soccer" },
                { id: "HRM-004", name: "Anytime goalscorer", desc: "Player to score at any time", type: "Player Props", sport: "Soccer" },
                { id: "HRM-005", name: "Total Corners", desc: "Over/Under total corners in the match", type: "Statistics", sport: "Soccer" }
            ];

            function renderHermesMarkets() {
                hermesMarketsBody.innerHTML = ''; 

                const searchVal = searchInput.value.toLowerCase();
                const sportVal = sportSelect.value;
                const typeVal = typeSelect.value;

                const filteredMarkets = hermesMarkets.filter(market => {
                    const matchesSearch = market.name.toLowerCase().includes(searchVal) || market.id.toLowerCase().includes(searchVal);
                    const matchesSport = market.sport.toLowerCase() === sportVal.toLowerCase();
                    const matchesType = typeVal === 'all' || market.type === typeVal;
                    
                    return matchesSearch && matchesSport && matchesType;
                });

                if (filteredMarkets.length === 0) {
                    hermesMarketsBody.innerHTML = '<tr><td colspan="6" style="text-align: center; color: #888; font-style: italic;">No markets found matching the filters.</td></tr>';
                    return;
                }

                filteredMarkets.forEach(market => {
                    const row = document.createElement('tr');
                    
                    row.innerHTML = `
                        <td style="font-weight: 500; color: #6c757d;">${market.id}</td>
                        <td class="market-name">${market.name}</td>
                        <td>${market.sport}</td>
                        <td style="color: #555; font-size: 14px;">${market.desc}</td>
                        <td><span style="background: #e9ecef; padding: 4px 10px; border-radius: 4px; font-size: 13px; border: 1px solid #ccc;">${market.type}</span></td>
                        <td style="text-align: right;">
                            <a href="view_hermes_market.html?id=${encodeURIComponent(market.id)}&market=${encodeURIComponent(market.name)}&sport=${encodeURIComponent(market.sport)}&type=${encodeURIComponent(market.type)}" class="btn-action" style="background-color: #007bff; text-decoration: none; display: inline-block;">View</a>
                        </td>
                    `;
                    hermesMarketsBody.appendChild(row);
                });
            }

            sportSelect.addEventListener('change', renderHermesMarkets);
            typeSelect.addEventListener('change', renderHermesMarkets);
            searchInput.addEventListener('input', renderHermesMarkets);

            renderHermesMarkets();
        });
    </script>
</body>
</html>
</file>

