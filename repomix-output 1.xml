                "Suspended": { bg: "#fff3cd", col: "#856404", border: "#ffeeba" },
                "Interrupted": { bg: "#fff3cd", col: "#856404", border: "#ffeeba" },
                "Postponed": { bg: "#f8d7da", col: "#721c24", border: "#f5c6cb" },
                "Abandoned": { bg: "#f8d7da", col: "#721c24", border: "#f5c6cb" }
            };

            // IZMENJENO: Punjenje feed dropdowna, prvo opcija je automatski izabrana
            function updateFeedDropdown() {
                const selectedProvider = providerSelect.value;
                feedSelect.innerHTML = ''; // Potpuno brisanje starog sadržaja
                
                if (selectedProvider && providerFeedsDatabase[selectedProvider]) {
                    providerFeedsDatabase[selectedProvider].forEach((feedName, index) => {
                        const option = document.createElement('option');
                        option.value = feedName;
                        option.textContent = feedName;
                        if(index === 0) option.selected = true; // Selektuj prvi feed
                        feedSelect.appendChild(option);
                    });
                }
            }

            function filterAndRender() {
                const providerVal = providerSelect.value;
                const feedVal = feedSelect.value;
                const sportVal = sportSelect.value;
                const statusVal = statusSelect.value;
                const searchVal = searchInput.value.toLowerCase();
                const isGrouped = groupByEventToggle.checked;

                if (isGrouped) {
                    tableHeader.innerHTML = `
                        <tr>
                            <th>Event ID</th>
                            <th>Provider event ID</th>
                            <th>Start time</th>
                            <th>Sport</th>
                            <th>Description</th>
                            <th>Status</th>
                            <th style="text-align: right;">Action</th>
                        </tr>
                    `;
                } else {
                    tableHeader.innerHTML = `
                        <tr>
                            <th>Event ID</th>
                            <th>Prov. Event ID</th>
                            <th>Timestamp</th>
                            <th>Sport</th>
                            <th>Status</th>
                            <th>Description</th>
                            <th>Message Type</th>
                            <th style="text-align: right;">Action</th>
                        </tr>
                    `;
                }

                const dataSource = isGrouped ? allEvents : allMessages;

                // IZMENJENO: Striktno proveravanje providera i feed-a bez 'all'
                filteredData = dataSource.filter(item => {
                    const matchesProvider = item.provider === providerVal;
                    const matchesFeed = item.feed === feedVal;
                    const matchesSport = sportVal === 'all' || item.sport === sportVal;
                    const matchesStatus = statusVal === 'all' || item.status === statusVal;
                    const matchesSearch = item.eventId.toLowerCase().includes(searchVal) || 
                                          item.desc.toLowerCase().includes(searchVal) || 
                                          item.provId.toLowerCase().includes(searchVal);
                    
                    return matchesProvider && matchesFeed && matchesSport && matchesStatus && matchesSearch;
                });

                if (isGrouped) {
                    filteredData.sort((a, b) => b.startTime.localeCompare(a.startTime)); 
                } else {
                    filteredData.sort((a, b) => b.time.localeCompare(a.time));
                }

                const totalPages = Math.ceil(filteredData.length / rowsPerPage) || 1;
                if (currentPage > totalPages) currentPage = totalPages;
                
                pageInfo.textContent = `Page ${currentPage} of ${totalPages}`;
                prevPageBtn.disabled = currentPage === 1;
                nextPageBtn.disabled = currentPage === totalPages;

                const startIndex = (currentPage - 1) * rowsPerPage;
                const paginatedItems = filteredData.slice(startIndex, startIndex + rowsPerPage);

                tableBody.innerHTML = "";
                
                if (paginatedItems.length === 0) {
                    const cols = isGrouped ? 7 : 8;
                    tableBody.innerHTML = `<tr><td colspan="${cols}" style="text-align: center; padding: 20px; color: #888;">No data found matching criteria.</td></tr>`;
                    return;
                }

                paginatedItems.forEach(item => {
                    const row = document.createElement("tr");
                    const colors = statusColors[item.status] || { bg: "#eee", col: "#333", border: "#ccc" };
                    
                    if (isGrouped) {
                        row.innerHTML = `
                            <td style="font-weight: 600; color: #007bff;">${item.eventId}</td>
                            <td style="color: #6c757d; font-size: 13px;">${item.provId}</td>
                            <td style="font-family: monospace; font-size: 13px;">${item.startTime}</td>
                            <td>${item.sport}</td>
                            <td style="font-weight: 500; color: #2c3e50;">${item.desc}</td>
                            <td><span class="status-badge" style="background-color: ${colors.bg}; color: ${colors.col}; border: 1px solid ${colors.border};">${item.status}</span></td>
                            <td style="text-align: right;">
                                <button class="btn-action" style="background-color: #17a2b8; border: none;">View Event</button>
                            </td>
                        `;
                    } else {
                        row.innerHTML = `
                            <td style="font-weight: 600; color: #007bff;">${item.eventId}</td>
                            <td style="color: #6c757d; font-size: 13px;">${item.provId}</td>
                            <td style="font-family: monospace; font-size: 13px;">${item.time}</td>
                            <td>${item.sport}</td>
                            <td><span class="status-badge" style="background-color: ${colors.bg}; color: ${colors.col}; border: 1px solid ${colors.border};">${item.status}</span></td>
                            <td>${item.desc}</td>
                            <td style="font-size: 13px; color: #555;">${item.type}</td>
                            <td style="text-align: right;">
                                <button class="btn-action" style="background-color: #17a2b8; border: none;">View Msg</button>
                            </td>
                        `;
                    }
                    tableBody.appendChild(row);
                });
            }

            // Slušači događaja
            providerSelect.addEventListener('change', () => { 
                updateFeedDropdown(); 
                currentPage = 1; 
                filterAndRender(); 
            });
            feedSelect.addEventListener('change', () => { currentPage = 1; filterAndRender(); });
            sportSelect.addEventListener('change', () => { currentPage = 1; filterAndRender(); });
            statusSelect.addEventListener('change', () => { currentPage = 1; filterAndRender(); });
            searchInput.addEventListener('input', () => { currentPage = 1; filterAndRender(); });
            
            groupByEventToggle.addEventListener('change', () => { 
                currentPage = 1; 
                filterAndRender(); 
            });
            
            rowsPerPageSelect.addEventListener('change', (e) => {
                rowsPerPage = parseInt(e.target.value);
                currentPage = 1;
                filterAndRender();
            });

            prevPageBtn.addEventListener('click', () => {
                if (currentPage > 1) { currentPage--; filterAndRender(); }
            });

            nextPageBtn.addEventListener('click', () => {
                const totalPages = Math.ceil(filteredData.length / rowsPerPage);
                if (currentPage < totalPages) { currentPage++; filterAndRender(); }
            });

            // Inicijalno postavljanje
            updateFeedDropdown();
            filterAndRender();
        });
    </script>
</body>
</html>
</file>

<file path="sports/map_sport.html">
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Map Sport</title>
    <!-- Povlačimo globalni CSS -->
    <link rel="stylesheet" href="../style.css">
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <div id="sidebar-container" data-root=".." data-active="sports-mapping"></div>
    <script src="../sidebar.js"></script>

    <!-- GLAVNI SADRŽAJ -->
    <div class="main-content">
        <header class="main-header">
            <h1>Map Provider Sport</h1>
        </header>

        <main class="split-layout">
            <div class="form-side">
                
                <div style="margin-bottom: 20px;">
                    <a href="sports_mapping.html" class="btn-secondary" style="text-decoration: none; display: inline-block;">&larr; Back to list</a>
                </div>

                <div class="info-section">
                    <h2>Connect to Hermes Sport</h2>
                    <p class="provider-text">Provider: <strong id="displayProvider"></strong></p>
                </div>

                <section class="section-card">
                    <h3 class="section-title">Mapping Configuration</h3>
                    
                    <div class="form-row" style="align-items: flex-end; margin-bottom: 20px;">
                        
                        <!-- Leva strana (Provider Info - Readonly) -->
                        <div class="form-group" style="flex: 1; margin-bottom: 0;">
                            <label>Provider Sport Name</label>
                            <input type="text" id="displayProvName" readonly style="background-color: #f9f9f9; color: #555; font-weight: 500;">
                        </div>

                        <div style="padding: 10px; font-weight: bold; color: #888;">
                            &rarr;
                        </div>

                        <!-- Desna strana (Hermes Selection) -->
                        <div class="form-group" style="flex: 1; margin-bottom: 0;">
                            <label>Choose Hermes Sport</label>
                            <input type="text" id="hermesSportSearch" placeholder="Search sports..." style="margin-bottom: 8px;">
                            <select id="hermesSportSelect">
                                <option value="" disabled selected>Search sports...</option>
                                <option value="S-001">Soccer (SOC)</option>
                                <option value="S-002">Basketball (BKB)</option>
                                <option value="S-003">Tennis (TEN)</option>
                                <option value="S-004">Ice Hockey (IHO)</option>
                                <option value="S-005">Baseball (BBS)</option>
                            </select>
                        </div>

                    </div>
                </section>

                <div class="actions-bar">
                    <button id="saveMappingBtn" class="btn-primary">Save Mapping</button>
                </div>
            </div>

            <!-- Uputstvo sa desne strane -->
            <aside class="info-side">
                <div class="sticky-info">
                    <h3 class="side-title">Sport Mapping Guidelines</h3>
                    <div class="info-block">
                        <h4>1-to-1 Mapping</h4>
                        <p>Za razliku od marketa, mapiranje sportova je jednostavno 1-na-1 povezivanje. Izaberite Provider sport i dodelite mu odgovarajući Hermes ekvivalent. Search polje iznad liste filtrira dostupne Hermes sportove.</p>
                    </div>
                    <div class="info-block">
                        <h4>Hermes Sports Missing?</h4>
                        <p>Ukoliko ne vidite traženi Hermes sport u padajućoj listi, prvo morate da ga kreirate u sekciji <strong>Sports -> Management</strong>.</p>
                    </div>
                </div>
            </aside>
        </main>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            // Čitanje iz URL parametara
            const urlParams = new URLSearchParams(window.location.search);
            const provider = urlParams.get('provider') || 'Unknown Provider';
            const provName = urlParams.get('provName') || 'Unknown Sport';
            const hermesId = urlParams.get('hermesId');
            const hermesSportSelect = document.getElementById('hermesSportSelect');
            const hermesSportSearch = document.getElementById('hermesSportSearch');
            const allHermesOptions = Array.from(hermesSportSelect.options).map(option => ({
                value: option.value,
                text: option.textContent,
                disabled: option.disabled,
                selected: option.selected
            }));

            // Prikaz na formi
            document.getElementById('displayProvider').textContent = provider;
            document.getElementById('displayProvName').value = provName;
            if (hermesId) {
                hermesSportSelect.value = hermesId;
            }

            function renderHermesOptions(searchValue = '') {
                const currentValue = hermesSportSelect.value;
                const normalizedSearch = searchValue.toLowerCase();
                hermesSportSelect.innerHTML = '';

                allHermesOptions.forEach(optionData => {
                    if (optionData.value && !optionData.text.toLowerCase().includes(normalizedSearch)) return;

                    const option = document.createElement('option');
                    option.value = optionData.value;
                    option.textContent = optionData.text;
                    option.disabled = optionData.disabled;
                    hermesSportSelect.appendChild(option);
                });

                if (Array.from(hermesSportSelect.options).some(option => option.value === currentValue)) {
                    hermesSportSelect.value = currentValue;
                }
            }

            hermesSportSearch.addEventListener('input', () => {
                renderHermesOptions(hermesSportSearch.value);
            });

            // Čuvanje mapiranja
            document.getElementById('saveMappingBtn').addEventListener('click', () => {
                if(!hermesSportSelect.value) {
                    alert('Please select a Hermes sport before saving.');
                    return;
                }
                alert(`Mapping saved successfully! Provider "${provName}" is now mapped to Hermes sport.`);
                window.location.href = 'sports_mapping.html';
            });
        });
    </script>
</body>
</html>
</file>

