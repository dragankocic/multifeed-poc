                        <div style="display: flex; gap: 10px;">
                            <a href="extended_specifiers.html" class="btn-secondary" style="text-decoration: none; background-color: #17a2b8; display: inline-block;">Edit Extended Specifiers</a>
                            <button type="button" id="addExtendedSpecifierBtn" class="btn-secondary">New extended specifier</button>
