                    <div class="info-block">
                        <h4>Zavisnost Entiteta (Dependencies)</h4>
                        <p>Sistem ne dozvoljava objavljivanje marketa ukoliko pripadajući sport već nije objavljen. Označavanje marketa će automatski označiti i njegov sport roditelj.</p>
                    </div>
                    <div class="info-block">
                        <h4>Verifikacija Mapiranja</h4>
                        <p>Klikom na <strong>View mapping</strong> možete uporediti sirovi provajderov JSON (Input) sa transformisanim Hermes JSON-om (Output). Opcija <strong>Edit mapping</strong> otvara mapiranje sporta ili marketa za izmenu.</p>
                    </div>
                </div>
            </aside>
        </main>
    </div>

    <div id="viewModal" class="modal">
        <div class="modal-content" style="max-width: 800px;">
            <span class="close-modal" id="closeViewModalBtn">&times;</span>
            <h3 style="margin-bottom: 15px; color: #333;">Mapping Verification</h3>
            <p style="font-size: 14px; color: #666;">Uporedni prikaz originalne poruke od provajdera i transformisane Hermes poruke.</p>
            
            <div class="split-modal-body">
                <div class="code-panel">
                    <h4>Provider Message (Input)</h4>
                    <pre id="providerMessageContent"></pre>
                </div>
                <div class="code-panel" style="background-color: #1e1e1e;">
                    <h4 style="border-bottom-color: #333;">Mapped Message (Output)</h4>
                    <pre id="mappedMessageContent"></pre>
                </div>
            </div>
        </div>
    </div>

    <div id="publishModal" class="modal">
        <div class="modal-content" style="max-width: 500px;">
            <h3 style="margin-bottom: 10px; color: #28a745;">Confirm Publish</h3>
            <p style="font-size: 14px; color: #555;">Sledeća mapiranja će biti objavljena u sistemu:</p>
            
            <div class="summary-list" id="publishSummaryList">
                </div>

            <div style="display: flex; justify-content: flex-end; gap: 15px; margin-top: 25px;">
                <button id="cancelPublishBtn" class="btn-secondary" style="padding: 10px 20px;">Cancel</button>
                <button id="confirmPublishBtn" class="btn-primary" style="background-color: #28a745; padding: 10px 20px;">Publish Changes</button>
            </div>
        </div>
    </div>

    <script src="../sidebar.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            
            // --- LOGIKA ZAVISNOSTI CHECKBOX-OVA ---
            const sportCheckboxes = document.querySelectorAll('.cb-sport');
            const marketCheckboxes = document.querySelectorAll('.cb-market');

            // 1. Ako čekiraš market, mora da se čekira i njegov sport
            marketCheckboxes.forEach(mCb => {
                mCb.addEventListener('change', (e) => {
                    if (e.target.checked) {
                        const parentId = e.target.getAttribute('data-parent');
                        const parentSportCb = document.querySelector(`.cb-sport[data-id="${parentId}"]`);
                        if (parentSportCb) parentSportCb.checked = true;
                    }
                });
            });

            // 2. Ako odčekiraš sport, moraju da se odčekiraju svi njegovi marketi
            sportCheckboxes.forEach(sCb => {
                sCb.addEventListener('change', (e) => {
                    if (!e.target.checked) {
                        const sportId = e.target.getAttribute('data-id');
                        const childMarkets = document.querySelectorAll(`.cb-market[data-parent="${sportId}"]`);
                        childMarkets.forEach(child => child.checked = false);
                    }
                });
            });


            // --- VIEW MODAL LOGIKA ---
            const viewModal = document.getElementById('viewModal');
            const closeViewModalBtn = document.getElementById('closeViewModalBtn');
            const providerContent = document.getElementById('providerMessageContent');
            const mappedContent = document.getElementById('mappedMessageContent');

            document.querySelectorAll('.view-btn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    const entityType = e.target.getAttribute('data-type');
                    const provName = e.target.getAttribute('data-prov');
                    const hermName = e.target.getAttribute('data-herm');

                    let mockProviderJson, mockMappedJson;

                    if (entityType === "sport") {
                        mockProviderJson = {
                            "source": "provider_feed",
                            "timestamp": new Date().toISOString(),
                            "entity_type": "sport",
                            "data": {
                                "provider_id": "sr:sport:1",
                                "name": provName
                            }
                        };

                        mockMappedJson = {
                            "routing_key": "hermes.mapping.sport",
                            "status": "published",
                            "mapped_data": {
                                "hermes_sport_id": "S-XXX",
                                "hermes_sport_name": hermName,
                                "provider_reference": "sr:sport:1"
                            }
                        };
                    } else {
                        // Dinamička izmena mock JSON-a za markete
                        mockProviderJson = {
                            "source": "provider_feed",
                            "timestamp": new Date().toISOString(),
                            "entity_type": "market",
                            "data": {
                                "market_name": provName,
                                "specifiers": {},
                                "outcomes": []
                            }
                        };

                        mockMappedJson = {
                            "routing_key": "hermes.mapping.market",
                            "status": "published",
                            "mapped_data": {
                                "hermes_market_id": "HRM-XXX",
                                "hermes_market_name": hermName,
                                "provider_reference": provName,
                                "mapped_specifiers": {},
                                "mapped_outcomes": []
                            }
                        };
                    }

                    providerContent.textContent = JSON.stringify(mockProviderJson, null, 2);
                    mappedContent.textContent = JSON.stringify(mockMappedJson, null, 2);
                    viewModal.style.display = 'flex';
                });
            });

            closeViewModalBtn.addEventListener('click', () => viewModal.style.display = 'none');


            // --- PUBLISH MODAL LOGIKA ---
            const publishModal = document.getElementById('publishModal');
            const triggerPublishBtn = document.getElementById('triggerPublishBtn');
            const cancelPublishBtn = document.getElementById('cancelPublishBtn');
            const confirmPublishBtn = document.getElementById('confirmPublishBtn');
            const summaryList = document.getElementById('publishSummaryList');

            triggerPublishBtn.addEventListener('click', () => {
                summaryList.innerHTML = '';
                let hasSelections = false;

                sportCheckboxes.forEach(sCb => {
                    if (sCb.checked) {
                        hasSelections = true;
                        const sportId = sCb.getAttribute('data-id');
                        const sportName = sCb.getAttribute('data-name');
                        
                        const sportHeader = document.createElement('div');
                        sportHeader.className = 'summary-sport-item';
                        sportHeader.textContent = `Sport: ${sportName}`;
                        summaryList.appendChild(sportHeader);

                        const childMarkets = document.querySelectorAll(`.cb-market[data-parent="${sportId}"]:checked`);
                        childMarkets.forEach(mCb => {
                            const marketName = mCb.getAttribute('data-name');
                            const marketItem = document.createElement('div');
                            marketItem.className = 'summary-market-item';
                            marketItem.textContent = marketName;
                            summaryList.appendChild(marketItem);
                        });
                    }
                });

                if (!hasSelections) {
                    alert("Molimo izaberite barem jedno mapiranje za objavljivanje.");
                    return;
                }

                publishModal.style.display = 'flex';
            });

            cancelPublishBtn.addEventListener('click', () => publishModal.style.display = 'none');

            confirmPublishBtn.addEventListener('click', () => {
                publishModal.style.display = 'none';
                alert("Mapiranja su uspešno objavljena!");
                
                document.querySelectorAll('input[type="checkbox"]').forEach(cb => cb.checked = false);
            });

            window.addEventListener('click', (e) => {
                if (e.target === viewModal) viewModal.style.display = 'none';
                if (e.target === publishModal) publishModal.style.display = 'none';
            });
        });
    </script>
</body>
</html>
</file>

