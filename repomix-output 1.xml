                            </tr>
                        </thead>
                        <tbody id="providerSportsList">
                            <!-- Dinamički se puni preko JS-a -->
                        </tbody>
                    </table>
                </section>
            </div>

            <aside class="info-side">
                <div class="sticky-info">
                    <h3 class="side-title">Business Guidelines</h3>
                    <div class="info-block">
                        <h4>Struktura Hermes Sporta</h4>
                        <p>Prikaz standardizovanih detalja za izabrani interni sport. Ovde vidimo jedinstveni Hermes ID i sistemsku skraćenicu.</p>
                    </div>
                    <div class="info-block">
                        <h4>Mapiranja Provajdera</h4>
                        <p>Prikaz svih provajderskih sportskih feed-ova koji su preusmereni na ovaj interni sport. Na primer, provajderov "Football" i provajderov "Soccer" se oba mapiraju na naš interni "Soccer".</p>
                    </div>
                    <div class="info-block">
                        <h4>Upravljanje Konekcijama</h4>
                        <p>Dugme <strong>Edit Mapping</strong> vas vodi direktno na formu gde možete promeniti ili raskinuti vezu između provajderskog sporta i našeg Hermes sporta.</p>
                    </div>
                </div>
            </aside>
        </main>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Čitanje informacija o sportu iz URL-a
            const urlParams = new URLSearchParams(window.location.search);
            const sportId = urlParams.get('id') || '-';
            const sportName = urlParams.get('name') || 'Unknown Sport';
            const sportAbbr = urlParams.get('abbr') || '-';

            // Prikaz podataka u zaglavlju
            document.getElementById('displaySportId').textContent = sportId;
            document.getElementById('displaySportName').textContent = sportName;
            document.getElementById('displaySportAbbr').textContent = sportAbbr;

            // Mock podaci: Koji provajder sportovi pokazuju na ovaj Hermes sport
            const reverseMappings = {
                "Soccer": [
                    { provider: "ExeFeed", provId: "-", provName: "Soccer" },
                    { provider: "SportRadar", provId: "sr:sport:1", provName: "Football" }
                ],
                "Basketball": [
                    { provider: "ExeFeed", provId: "-", provName: "Basketball" }
                ]
            };

            const mappedList = reverseMappings[sportName] || [];
            const listContainer = document.getElementById('providerSportsList');

            if (mappedList.length === 0) {
                listContainer.innerHTML = '<tr><td colspan="4" style="text-align: center; color: #888; font-style: italic;">No provider sports mapped to this Hermes sport yet.</td></tr>';
            } else {
                mappedList.forEach(prov => {
                    const tr = document.createElement('tr');
                    tr.innerHTML = `
                        <td style="font-weight: 500;">${prov.provider}</td>
                        <td style="color: #6c757d;">${prov.provId}</td>
                        <td style="color: #007bff; font-weight: 500;">${prov.provName}</td>
                        <td style="text-align: right;">
                            <a href="map_sport.html?provider=${encodeURIComponent(prov.provider)}&provName=${encodeURIComponent(prov.provName)}" class="btn-action" style="background-color: #17a2b8; text-decoration: none; display: inline-block; margin-right: 8px;">Edit Mapping</a>
                        </td>
                    `;
                    listContainer.appendChild(tr);
                });
            }
        });
    </script>
</body>
</html>
