                    <div class="form-group">
                        <label>Outcomes Type</label>
                        <div class="radio-group" id="outcomesTypeGroup">
                            <label><input type="radio" name="outcomesType" value="Regular"> Regular</label>
                            <label><input type="radio" name="outcomesType" value="Competitors"> Competitors</label>
                            <label><input type="radio" name="outcomesType" value="Players"> Players</label>
                        </div>
                    </div>

                    <div id="regularOutcomesWrapper" style="display: none; margin-top: 20px; border-top: 1px dashed #ccc; padding-top: 15px;">
