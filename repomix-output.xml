<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>View Provider Feeds</title>
    <link rel="stylesheet" href="feeds_style.css">
    <link rel="stylesheet" href="../style.css">
</head>
<body>

    <div id="sidebar-container" data-root=".." data-active="feeds-management"></div>

    <div class="main-content">
        <header class="main-header">
            <h1>Provider Feeds Configuration</h1>
        </header>

        <main class="dashboard-container">
            
            <div style="margin-bottom: 20px;">
                <a href="feeds.html" class="btn-secondary" style="text-decoration: none; display: inline-block;">&larr; Back to Management</a>
            </div>

            <div class="top-bar" style="display: flex; justify-content: space-between; align-items: center; background-color: white; padding: 20px; border-radius: 8px; border: 1px solid #e0e0e0; box-shadow: 0 2px 5px rgba(0,0,0,0.05); margin-bottom: 30px;">
                <div>
                    <h2 style="color: #2c3e50; font-size: 22px; margin: 0;">
                        Provider: <span id="displayProviderName" style="color: #007bff;"></span>
                    </h2>
                </div>
                <div class="actions">
                    <button id="addNewFeedBtn" class="btn-primary" style="background-color: #28a745; border: none;">Add new feed</button>
                </div>
            </div>

            <section class="markets-section">
                <table class="markets-table">
                    <thead>
                        <tr>
                            <th>Feed Name</th>
                            <th>Description</th>
                            <th style="text-align: right;">Action</th>
                        </tr>
                    </thead>
                    <tbody id="feedsListBody">
                        </tbody>
                </table>
            </section>

        </main>
    </div>

    <div id="feedModal" class="modal">
        <div class="modal-content">
            <span class="close-modal" id="closeFeedModalBtn">&times;</span>
            <h3 id="modalTitle">Add new feed</h3>
            
            <div class="form-group" style="margin-top: 15px;">
                <label for="feedNameInput">Feed Name</label>
                <input type="text" id="feedNameInput" placeholder="Enter feed name">
            </div>

            <div class="form-group" style="margin-top: 15px;">
                <label for="feedDescInput">Description</label>
                <input type="text" id="feedDescInput" placeholder="Enter feed description">
            </div>
            
            <div style="text-align: right; margin-top: 20px;">
                <button id="saveFeedBtn" class="btn-primary" style="background-color: #28a745;">Save</button>
            </div>
        </div>
    </div>

    <script src="../sidebar.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const feedsListBody = document.getElementById('feedsListBody');
            const displayProviderName = document.getElementById('displayProviderName');
            
            // Modal elementi
            const modal = document.getElementById('feedModal');
            const addNewFeedBtn = document.getElementById('addNewFeedBtn');
            const closeFeedModalBtn = document.getElementById('closeFeedModalBtn');
            const saveFeedBtn = document.getElementById('saveFeedBtn');
            const modalTitle = document.getElementById('modalTitle');
            const feedNameInput = document.getElementById('feedNameInput');
            const feedDescInput = document.getElementById('feedDescInput');

            // Čitanje naziva provajdera iz URL parametra
            const urlParams = new URLSearchParams(window.location.search);
            const providerName = urlParams.get('provider') || 'Unknown Provider';
            displayProviderName.textContent = providerName;

            // Mock baza feed-ova usklađena po veličini i nazivima sa prethodne stranice
            const providerFeedsDatabase = {
                "ExeFeed": [
                    { name: "Exe-Live", desc: "Real-time live odds data stream for active matches." },
                    { name: "Exe-Prematch", desc: "Pre-match fixtures, baseline odds, and market definitions." }
                ],
                "SportRadar": [
                    { name: "SR-LiveOdds", desc: "Live betting coverage with fast-path data." },
                    { name: "SR-MTS", desc: "Managed Trading Services automated platform integration." },
                    { name: "SR-PreMatch", desc: "Pre-match schedules and comprehensive statistics." },
                    { name: "SR-Resulting", desc: "Official match scoring and final market settlements." }
                ],
                "Bet Genius": [
                    { name: "BG-GeniusOdds", desc: "Core sportsbook trading and pricing management feed." }
                ],
                "IMG Arena": [
                    { name: "IMG-TennisLive", desc: "Ultra-low latency live data specifically for tennis tournaments." },
                    { name: "IMG-GolfTrack", desc: "Advanced data points for golf tournament shot tracking." },
                    { name: "IMG-PreOdds", desc: "Pre-event baseline fixtures and scheduling setup." }
                ],
                "Bet Construct": [
                    { name: "BC-MainLive", desc: "Standard live odds feed for multiple global sport events." },
                    { name: "BC-PrematchData", desc: "Pre-match market initialization data structures." },
                    { name: "BC-Scouting", desc: "Direct pitch-side scout reporting and statistics data." },
                    { name: "BC-Virtuals", desc: "Virtual sports betting simulation graphics and odds feed." },
                    { name: "BC-CryptoFeed", desc: "Specialized feed targeting decentralized and crypto markets." }
                ],
                "LSports": [
                    { name: "LS-STM", desc: "Sports Trading Manager automated live feed engine." },
                    { name: "LS-PreMatch", desc: "Standard pre-match market initialize codes and data." }
                ]
            };

            // Uzimamo niz feed-ova za trenutnog provajdera (ili prazan niz ako ne postoji)
            let currentFeeds = providerFeedsDatabase[providerName] || [];
            let editIndex = null; // Prati da li radimo Add ili Edit

            // Funkcija za iscrtavanje tabele
            function renderFeedsTable() {
                feedsListBody.innerHTML = '';

                if (currentFeeds.length === 0) {
                    feedsListBody.innerHTML = '<tr><td colspan="3" style="text-align: center; color: #888; font-style: italic;">No feeds configured for this provider.</td></tr>';
                    return;
                }

                currentFeeds.forEach((feed, index) => {
                    const row = document.createElement('tr');
                    row.innerHTML = `
                        <td class="market-name">${feed.name}</td>
                        <td style="color: #555; font-size: 14px;">${feed.desc}</td>
                        <td style="text-align: right;">
                            <button class="btn-action edit-feed-btn" style="background-color: #17a2b8; border: none; cursor: pointer;" data-index="${index}">Edit</button>
                        </td>
                    `;
                    feedsListBody.appendChild(row);
                });

                // Kačenje listener-a na Edit dugmiće
                document.querySelectorAll('.edit-feed-btn').forEach(btn => {
                    btn.addEventListener('click', (e) => {
                        const index = parseInt(e.target.dataset.index);
                        openModalForEdit(index);
                    });
                });
            }

            // --- Modal Logika ---

            // Otvaranje za kreiranje novog
            addNewFeedBtn.addEventListener('click', () => {
                editIndex = null;
                modalTitle.textContent = "Add new feed";
                feedNameInput.value = '';
                feedDescInput.value = '';
                modal.style.display = 'flex';
                feedNameInput.focus();
            });

            // Otvaranje za izmenu postojećeg
            function openModalForEdit(index) {
                editIndex = index;
                const feed = currentFeeds[index];
                modalTitle.textContent = "Edit feed";
                feedNameInput.value = feed.name;
                feedDescInput.value = feed.desc;
                modal.style.display = 'flex';
                feedNameInput.focus();
            }

            // Zatvaranje modala
            closeFeedModalBtn.addEventListener('click', () => {
                modal.style.display = 'none';
            });

            window.addEventListener('click', (e) => {
                if (e.target === modal) modal.style.display = 'none';
            });

            // Akcija čuvanja (i za Add i za Edit)
            saveFeedBtn.addEventListener('click', () => {
                const name = feedNameInput.value.trim();
                const desc = feedDescInput.value.trim();

                if (!name || !desc) {
                    alert('Both Feed Name and Description are required.');
                    return;
                }

                if (editIndex !== null) {
                    // Update mod
                    currentFeeds[editIndex].name = name;
                    currentFeeds[editIndex].desc = desc;
                    alert(`Feed successfully updated!`);
                } else {
                    // Create mod
                    currentFeeds.push({ name: name, desc: desc });
                    alert(`New feed successfully added!`);
                }

                modal.style.display = 'none';
                renderFeedsTable();
            });

            // Inicijalno iscrtavanje po učitavanju stranice
            renderFeedsTable();
        });
    </script>
</body>
</html>
</file>

<file path="feeds/feeds.html">
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Feeds Management</title>
    <link rel="stylesheet" href="feeds_style.css">
    <link rel="stylesheet" href="../style.css">
</head>
<body>

    <div id="sidebar-container" data-root=".." data-active="feeds-management"></div>

    <div class="main-content">
        <header class="main-header" style="background-color: #2c3e50; color: white;">
            <h1>Feeds Management</h1>
        </header>

        <main class="dashboard-container">
            
            <div class="top-bar">
                <div class="filters">
                    <div class="filter-group">
                        <label for="feedsSearchInput">Search Providers</label>
                        <input type="text" id="feedsSearchInput" placeholder="Search by provider name..." style="padding: 10px 15px; border: 1px solid #ccc; border-radius: 4px; font-size: 15px; min-width: 280px; background-color: #fdfdfd;">
                    </div>
                </div>

                <div class="actions">
                    <button id="addProviderBtn" class="btn-primary" style="background-color: #28a745; border: none;">Add provider</button>
                </div>
            </div>

            <section class="markets-section">
                <table class="markets-table">
                    <thead>
                        <tr>
                            <th>Provider Name</th>
                            <th>Number of Feeds</th>
                            <th style="text-align: right;">Action</th>
                        </tr>
                    </thead>
                    <tbody id="feedsTableBody">
                        </tbody>
                </table>
            </section>
        </main>
    </div>

    <div id="providerModal" class="modal">
        <div class="modal-content">
            <span class="close-modal" id="closeModalBtn">&times;</span>
            <h3>Add new provider</h3>
            
            <div class="form-group" style="margin-top: 15px;">
                <label for="providerNameInput">Provider Name</label>
                <input type="text" id="providerNameInput" placeholder="Enter provider name">
            </div>
            
            <div style="text-align: right; margin-top: 20px;">
                <button id="saveProviderBtn" class="btn-primary" style="background-color: #28a745;">Save</button>
            </div>
        </div>
    </div>

    <script src="../sidebar.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const tableBody = document.getElementById('feedsTableBody');
            const searchInput = document.getElementById('feedsSearchInput');
            
            // Modal elementi
            const modal = document.getElementById('providerModal');
            const addProviderBtn = document.getElementById('addProviderBtn');
            const closeModalBtn = document.getElementById('closeModalBtn');
            const saveProviderBtn = document.getElementById('saveProviderBtn');
            const providerNameInput = document.getElementById('providerNameInput');

            // Početna lista provajdera sa zahtevanim brojem feed-ova
            const providersList = [
                { name: "ExeFeed", count: 2 },
                { name: "SportRadar", count: 4 },
                { name: "Bet Genius", count: 1 },
                { name: "IMG Arena", count: 3 },
                { name: "Bet Construct", count: 5 },
                { name: "LSports", count: 2 }
            ];

            // Funkcija za iscrtavanje tabele sa filtriranjem
            function renderFeeds() {
                tableBody.innerHTML = '';
                const searchVal = searchInput.value.toLowerCase();

                const filtered = providersList.filter(p => p.name.toLowerCase().includes(searchVal));

                if (filtered.length === 0) {
                    tableBody.innerHTML = '<tr><td colspan="3" style="text-align: center; color: #888; font-style: italic;">No providers found.</td></tr>';
                    return;
                }

                filtered.forEach(p => {
                    const row = document.createElement('tr');
                    row.innerHTML = `
                        <td class="market-name">${p.name}</td>
                        <td><span style="background: #e9ecef; padding: 4px 12px; border-radius: 4px; font-weight: 600; border: 1px solid #ccc; font-size: 13px;">${p.count}</span></td>
                        <td style="text-align: right;">
                            <a href="feeds_view.html?provider=${encodeURIComponent(p.name)}" class="btn-action" style="background-color: #007bff; text-decoration: none; display: inline-block;">View</a>
                        </td>
                    `;
                    tableBody.appendChild(row);
                });
            }

            // Slušač za tekstualnu pretragu uživo
            searchInput.addEventListener('input', renderFeeds);

            // --- Modal Logika ---
            addProviderBtn.addEventListener('click', () => {
                modal.style.display = 'flex';
                providerNameInput.value = '';
                providerNameInput.focus();
            });

            closeModalBtn.addEventListener('click', () => {
                modal.style.display = 'none';
            });

            window.addEventListener('click', (e) => {
                if (e.target === modal) modal.style.display = 'none';
            });

            saveProviderBtn.addEventListener('click', () => {
                const name = providerNameInput.value.trim();
                if (!name) return alert('Provider name is required');

                // Dodavanje novog provajdera sa random brojem feedova (1-5)
                const randomCount = Math.floor(Math.random() * 5) + 1;
                providersList.push({ name: name, count: randomCount });

                modal.style.display = 'none';
                renderFeeds();
                alert(`Provider "${name}" successfully added!`);
            });

            // Prvo učitavanje
            renderFeeds();
        });
    </script>
</body>
</html>
</file>

