    <script>
        document.addEventListener("DOMContentLoaded", () => {
            // Čitanje iz URL parametara
            const urlParams = new URLSearchParams(window.location.search);
            const provider = urlParams.get('provider') || 'Unknown Provider';
            const provName = urlParams.get('provName') || 'Unknown Sport';

            // Prikaz na formi
            document.getElementById('displayProvider').textContent = provider;
            document.getElementById('displayProvName').value = provName;

            // Čuvanje mapiranja
            document.getElementById('saveMappingBtn').addEventListener('click', () => {
                const hermesSelect = document.getElementById('hermesSportSelect');
                if(!hermesSelect.value) {
                    alert('Please select a Hermes sport before saving.');
                    return;
                }
                alert(`Mapping saved successfully! Provider "${provName}" is now mapped to Hermes sport.`);
                window.location.href = 'sports_mappings.html';
            });
        });
    </script>
</body>
</html>
