<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hermes Sport Overview</title>
    <!-- Lokalni i globalni CSS -->
    <link rel="stylesheet" href="style.css">
    <link rel="stylesheet" href="../style.css">
</head>
<body>

   <div id="sidebar-container" data-root=".." data-active="sports-mappings"></div>
    <script src="../sidebar.js"></script>

    <!-- GLAVNI SADRŽAJ -->
    <div class="main-content">
        <header class="main-header" style="background-color: #17a2b8; color: white;">
            <h1>Hermes Sport Overview</h1>
        </header>

        <main class="dashboard-container" style="max-width: 900px;">
            
            <div style="margin-bottom: 20px;">
                <a href="hermes_sports.html" class="btn-secondary" style="text-decoration: none; display: inline-block;">&larr; Back to Hermes Sports</a>
            </div>

            <!-- Zaglavlje sa detaljima o sportu -->
            <section class="top-bar" style="display: block; background-color: white; padding: 25px; border-radius: 8px; border: 1px solid #e0e0e0;">
                <h2 style="margin-bottom: 15px; color: #2c3e50; font-size: 24px;">
                    Hermes Sport: <span id="displaySportName" style="color: #17a2b8;"></span>
                </h2>
                <div style="display: flex; gap: 30px; border-top: 1px dashed #ccc; padding-top: 15px;">
                    <p style="font-size: 16px; color: #555;">Sport ID: <strong id="displaySportId" style="color: #333;"></strong></p>
                    <p style="font-size: 16px; color: #555;">Abbreviation: <strong id="displaySportAbbr" style="color: #333;"></strong></p>
                </div>
            </section>

            <!-- Tabela mapiranih provider sportova -->
            <section class="markets-section" style="margin-top: 25px; padding: 25px; background: white; border-radius: 8px; border: 1px solid #e0e0e0;">
                <h3 style="margin-bottom: 20px; color: #333; font-size: 18px; border-bottom: 1px solid #eee; padding-bottom: 10px;">Mapped Provider Sports</h3>
                <p style="margin-bottom: 15px; font-size: 14px; color: #666;">Lista sportova od različitih provajdera koji su izmapirani na ovaj Hermes sport.</p>
                
                <table class="markets-table" style="margin-bottom: 25px;">
                    <thead>
                        <tr>
                            <th>Provider</th>
                            <th>Provider Sport ID</th>
                            <th>Provider Sport Name</th>
                            <th style="text-align: right;">Action</th>
                        </tr>
                    </thead>
                    <tbody id="providerSportsList">
                        <!-- Dinamički se puni preko JS-a -->
                    </tbody>
                </table>
            </section>

        </main>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Čitanje informacija o sportu iz URL-a
            const urlParams = new URLSearchParams(window.location.search);
            const sportId = urlParams.get('id') || '-';
            const sportName = urlParams.get('name') || 'Unknown Sport';
            const sportAbbr = urlParams.get('abbr') || '-';

            // Prikaz podataka u zaglavlju
            document.getElementById('displaySportId').textContent = sportId;
            document.getElementById('displaySportName').textContent = sportName;
            document.getElementById('displaySportAbbr').textContent = sportAbbr;

            // Mock podaci: Koji provajder sportovi pokazuju na ovaj Hermes sport
            const reverseMappings = {
                "Soccer": [
                    { provider: "ExeFeed", provId: "-", provName: "Soccer" },
                    { provider: "SportRadar", provId: "sr:sport:1", provName: "Football" }
                ],
                "Basketball": [
                    { provider: "ExeFeed", provId: "-", provName: "Basketball" }
                ]
            };

            const mappedList = reverseMappings[sportName] || [];
            const listContainer = document.getElementById('providerSportsList');

            if (mappedList.length === 0) {
                listContainer.innerHTML = '<tr><td colspan="4" style="text-align: center; color: #888; font-style: italic;">No provider sports mapped to this Hermes sport yet.</td></tr>';
            } else {
                mappedList.forEach(prov => {
                    const tr = document.createElement('tr');
                    tr.innerHTML = `
                        <td style="font-weight: 500;">${prov.provider}</td>
                        <td style="color: #6c757d;">${prov.provId}</td>
                        <td style="color: #007bff; font-weight: 500;">${prov.provName}</td>
                        <td style="text-align: right;">
                            <a href="map_sport.html?provider=${encodeURIComponent(prov.provider)}&provName=${encodeURIComponent(prov.provName)}" class="btn-action" style="background-color: #17a2b8; text-decoration: none; display: inline-block; margin-right: 8px;">Edit Mapping</a>
                        </td>
                    `;
                    listContainer.appendChild(tr);
                });
            }
        });
    </script>
</body>
</html>
