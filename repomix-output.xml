<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Map Sport</title>
    <!-- Povlačimo globalni CSS -->
    <link rel="stylesheet" href="../style.css">
    <link rel="stylesheet" href="style.css">
